<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Noir Executive</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%230a0a0a'/><text x='50' y='68' text-anchor='middle' font-size='50' font-family='Georgia,serif' fill='%23c9a84c'>A</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap');

      *{margin:0;padding:0;box-sizing:border-box}

      :root{
        --bg:#0a0a0a;
        --bg2:#111;
        --gold:#c9a84c;
        --gold-dim:#8a7535;
        --gold-glow:rgba(201,168,76,0.15);
        --text:#b8b8b8;
        --dim:#555;
        --bright:#f0f0f0;
        --white:#fff;
        --border:rgba(201,168,76,0.12);
        --serif:'Cormorant Garamond',Georgia,serif;
        --sans:'Inter',sans-serif;
      }

      body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.6}

      /* Subtle gold grain overlay */
      body::before{
        content:'';position:fixed;inset:0;
        background:radial-gradient(ellipse at 50% 0%,rgba(201,168,76,0.03),transparent 60%);
        pointer-events:none;z-index:0;
      }

      .noir-page{position:relative;z-index:1;max-width:860px;margin:0 auto;padding:3rem 2rem 5rem}

      .back-link{display:inline-block;font-size:.7rem;color:var(--dim);text-decoration:none;margin-bottom:2rem;letter-spacing:.15em;text-transform:uppercase}
      .back-link:hover{color:var(--gold)}

      /* Thin gold lines */
      .gold-line{height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:2.5rem 0}
      .gold-line-thick{height:2px;background:var(--gold);margin:2.5rem 0}

      /* Hero */
      .noir-hero{text-align:center;padding:4rem 0 3rem}

      .noir-hero h1{
        font-family:var(--serif);font-size:clamp(3rem,8vw,5rem);
        font-weight:300;letter-spacing:.08em;text-transform:uppercase;
        color:var(--white);line-height:1;margin-bottom:.8rem;
      }

      .noir-hero .title{
        font-family:var(--serif);font-size:1.3rem;font-weight:300;
        color:var(--gold);letter-spacing:.15em;text-transform:uppercase;
      }

      .noir-hero .sub{
        font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;
        color:var(--dim);margin-top:.5rem;
      }

      .noir-hero .loc{
        font-family:var(--serif);font-size:.95rem;font-style:italic;
        color:var(--dim);margin-top:.3rem;
      }

      .noir-contacts{
        display:flex;justify-content:center;flex-wrap:wrap;gap:.8rem;margin-top:2rem;
      }
      .noir-contacts a{
        font-size:.72rem;letter-spacing:.08em;color:var(--dim);text-decoration:none;
        padding:.5rem 1rem;border:1px solid rgba(201,168,76,0.15);
        transition:all .4s;
      }
      .noir-contacts a:hover{
        color:var(--gold);border-color:var(--gold);
        box-shadow:0 0 20px var(--gold-glow);
      }

      /* Summary */
      .noir-summary{
        font-family:var(--serif);font-size:1.2rem;font-weight:300;
        line-height:2;text-align:center;max-width:680px;margin:0 auto;
        color:var(--text);
      }
      .noir-summary strong{color:var(--gold);font-weight:500}

      /* Section */
      .noir-section{margin-bottom:0}

      .noir-label{
        font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.35em;
        color:var(--gold);text-align:center;margin-bottom:2rem;
      }

      /* Skills */
      .noir-skills{display:flex;justify-content:center;flex-wrap:wrap;gap:.5rem}
      .noir-skill{
        font-size:.78rem;letter-spacing:.05em;padding:.4rem 1rem;
        border:1px solid rgba(201,168,76,0.1);color:var(--text);
        transition:all .4s;
      }
      .noir-skill:hover{
        color:var(--gold);border-color:rgba(201,168,76,0.4);
        box-shadow:0 0 15px var(--gold-glow);
      }

      /* Experience */
      .noir-exp-item{
        padding:2rem 0;border-bottom:1px solid rgba(201,168,76,0.06);
      }
      .noir-exp-item:last-child{border-bottom:none}

      .noir-exp-header{
        display:flex;flex-wrap:wrap;justify-content:space-between;align-items:baseline;
        gap:.5rem;margin-bottom:.5rem;
      }

      .noir-exp-role{
        font-family:var(--serif);font-size:1.2rem;font-weight:500;color:var(--white);
      }
      .noir-exp-company{font-weight:300;color:var(--gold);font-style:italic}
      .noir-exp-date{font-size:.75rem;letter-spacing:.1em;color:var(--dim)}

      .noir-exp-bullets{list-style:none;padding:0}
      .noir-exp-bullets li{
        font-size:.88rem;padding:.2rem 0 .2rem 1.5rem;position:relative;color:var(--text);
      }
      .noir-exp-bullets li::before{
        content:'';position:absolute;left:0;top:.65rem;
        width:12px;height:1px;background:var(--gold);
      }

      /* Projects */
      .noir-proj-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(201,168,76,0.08)}

      .noir-proj{
        background:var(--bg);padding:2rem;transition:all .4s;
      }
      .noir-proj:hover{background:var(--bg2)}

      .noir-proj h3{
        font-family:var(--serif);font-size:1.15rem;font-weight:500;color:var(--white);
        letter-spacing:.02em;
      }
      .noir-proj .ptype{font-size:.75rem;color:var(--gold);font-style:italic}
      .noir-proj .plink{font-size:.7rem;margin:.2rem 0}
      .noir-proj .plink a{color:var(--dim);text-decoration:none;transition:color .3s}
      .noir-proj .plink a:hover{color:var(--gold)}
      .noir-proj p{font-size:.82rem;color:var(--dim);line-height:1.5;margin-top:.3rem}
      .noir-proj .ptags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.5rem}
      .noir-proj .ptags span{font-size:.7rem;color:var(--gold-dim);letter-spacing:.05em}

      /* Education & Languages */
      .noir-two-col{display:flex;flex-wrap:wrap;justify-content:center;gap:4rem;text-align:center}

      .noir-info h3{font-family:var(--serif);font-size:1.2rem;font-weight:500;color:var(--white)}
      .noir-info p{font-family:var(--serif);font-style:italic;color:var(--gold);font-size:.95rem}

      .noir-langs{display:flex;justify-content:center;flex-wrap:wrap;gap:2rem}
      .noir-lang .name{font-family:var(--serif);font-weight:500;color:var(--white);font-size:1rem;letter-spacing:.05em}
      .noir-lang .level{font-size:.75rem;color:var(--dim);margin-left:.3rem;font-style:italic}

      /* Footer */
      .noir-footer{
        margin-top:0;padding:2rem 0;text-align:center;
      }
      .noir-footer p{font-size:.85rem;color:var(--dim)}
      .noir-footer a{color:var(--gold);text-decoration:none;font-weight:500}
      .noir-footer-links{display:flex;justify-content:center;gap:2rem;margin-top:1rem}
      .noir-footer-links a{font-size:.75rem;color:var(--dim);text-decoration:none;letter-spacing:.1em;text-transform:uppercase;transition:color .3s}
      .noir-footer-links a:hover{color:var(--gold)}

      @media(max-width:640px){
        .noir-page{padding:2rem 1.5rem 3rem}
        .noir-exp-header{flex-direction:column}
        .noir-proj-grid{grid-template-columns:1fr}
        .noir-two-col{flex-direction:column;gap:2rem}
      }

      @media print{
        body::before{display:none}
        body{background:#fff;color:#333}
        .back-link{display:none}
        .noir-hero h1{color:#111}
        .gold-line,.gold-line-thick{background:#ddd}
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
