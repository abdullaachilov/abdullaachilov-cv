<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Holographic</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='%23ff6bff'/><stop offset='50%' stop-color='%2300e5ff'/><stop offset='100%' stop-color='%2300ff88'/></linearGradient></defs><rect width='100' height='100' rx='15' fill='%23111'/><text x='50' y='68' text-anchor='middle' font-size='50' font-weight='bold' fill='url(%23g)'>A</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

      *{margin:0;padding:0;box-sizing:border-box}

      :root{
        --bg:#0e0e12;
        --card:rgba(20,20,30,0.6);
        --text:#d8d8e8;
        --dim:#6b6b80;
        --bright:#fff;
        --holo-1:#ff6bff;
        --holo-2:#00e5ff;
        --holo-3:#00ff88;
        --holo-4:#ffb800;
        --holo-grad:linear-gradient(135deg,var(--holo-1),var(--holo-2),var(--holo-3));
        --border:rgba(255,255,255,0.06);
        --border-holo:linear-gradient(135deg,rgba(255,107,255,0.3),rgba(0,229,255,0.3),rgba(0,255,136,0.3));
      }

      body{
        font-family:'Sora',sans-serif;background:var(--bg);color:var(--text);
        line-height:1.6;overflow-x:hidden;
      }

      /* Ambient glow orbs */
      body::before,body::after{
        content:'';position:fixed;border-radius:50%;pointer-events:none;filter:blur(100px);z-index:0;
      }
      body::before{
        width:500px;height:500px;top:-100px;right:-100px;
        background:radial-gradient(circle,rgba(255,107,255,0.1),transparent 70%);
      }
      body::after{
        width:600px;height:600px;bottom:-150px;left:-150px;
        background:radial-gradient(circle,rgba(0,229,255,0.08),transparent 70%);
      }

      .holo-page{position:relative;z-index:1;max-width:920px;margin:0 auto;padding:2rem 1.5rem 4rem}

      .back-link{display:inline-block;font-size:.75rem;color:var(--dim);text-decoration:none;margin-bottom:1.5rem}
      .back-link:hover{color:var(--holo-2)}

      /* Holographic border card */
      .holo-card{
        position:relative;border-radius:16px;padding:2px;margin-bottom:1.5rem;
        background:linear-gradient(135deg,rgba(255,107,255,0.2),rgba(0,229,255,0.2),rgba(0,255,136,0.2));
      }
      .holo-card-inner{
        background:var(--card);backdrop-filter:blur(30px);-webkit-backdrop-filter:blur(30px);
        border-radius:14px;padding:2rem;position:relative;overflow:hidden;
      }
      .holo-card-inner::before{
        content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;
        background:conic-gradient(from 0deg,transparent,rgba(255,107,255,0.03),transparent,rgba(0,229,255,0.03),transparent,rgba(0,255,136,0.03),transparent);
        animation:holo-spin 8s linear infinite;pointer-events:none;
      }
      @keyframes holo-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

      /* Hero */
      .holo-hero .holo-card-inner{padding:3.5rem 2.5rem;text-align:center}

      .holo-badge{
        display:inline-block;font-size:.6rem;font-weight:600;text-transform:uppercase;
        letter-spacing:.2em;padding:.3rem .8rem;border-radius:999px;margin-bottom:1rem;
        background:linear-gradient(135deg,rgba(255,107,255,0.15),rgba(0,229,255,0.15));
        color:var(--holo-2);
      }

      .holo-hero h1{
        font-size:clamp(2.5rem,6vw,4rem);font-weight:800;letter-spacing:-.02em;
        background:var(--holo-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;
        background-clip:text;line-height:1.1;margin-bottom:.5rem;
      }

      .holo-hero .title{font-size:1.15rem;font-weight:500;color:var(--bright);margin-bottom:.2rem}
      .holo-hero .sub{font-size:.8rem;color:var(--dim);letter-spacing:.08em}
      .holo-hero .loc{font-size:.85rem;color:var(--dim);margin-top:.2rem}

      .holo-links{display:flex;justify-content:center;flex-wrap:wrap;gap:.5rem;margin-top:1.5rem}
      .holo-links a{
        font-size:.78rem;color:var(--dim);text-decoration:none;
        padding:.4rem .9rem;border-radius:999px;border:1px solid var(--border);
        transition:all .3s;position:relative;overflow:hidden;
      }
      .holo-links a:hover{
        color:var(--bright);
        border-image:var(--border-holo) 1;
        border-image-slice:1;
        background:linear-gradient(135deg,rgba(255,107,255,0.08),rgba(0,229,255,0.08));
      }

      /* Iridescent stat cards */
      .stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2px;margin-bottom:1.5rem}
      .stat-card{position:relative;border-radius:14px;padding:2px;background:var(--border-holo)}
      .stat-card-inner{
        background:var(--bg);border-radius:12px;padding:1.3rem;text-align:center;
      }
      .stat-num{
        font-size:2rem;font-weight:800;line-height:1;margin-bottom:.2rem;
        background:var(--holo-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      }
      .stat-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.2em;color:var(--dim);font-weight:600}

      /* Section label */
      .holo-label{
        font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;
        margin-bottom:1.5rem;
        background:var(--holo-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      }

      /* Skills */
      .holo-skills{display:flex;flex-wrap:wrap;gap:.4rem}
      .holo-skill{
        font-size:.78rem;padding:.35rem .8rem;border-radius:999px;
        border:1px solid var(--border);color:var(--text);
        transition:all .3s;position:relative;
      }
      .holo-skill:hover{
        background:linear-gradient(135deg,rgba(255,107,255,0.1),rgba(0,229,255,0.1));
        border-color:rgba(0,229,255,0.3);color:var(--bright);
      }

      /* Timeline */
      .holo-tl-item{padding:1.2rem 0;border-bottom:1px solid rgba(255,255,255,0.04)}
      .holo-tl-item:last-child{border-bottom:none}
      .holo-tl-header{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:baseline;gap:.5rem;margin-bottom:.4rem}
      .holo-tl-role{font-size:1rem;font-weight:700;color:var(--bright)}
      .holo-tl-company{font-weight:400;color:var(--holo-2)}
      .holo-tl-date{font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--dim)}
      .holo-tl-bullets{list-style:none;padding:0}
      .holo-tl-bullets li{font-size:.85rem;padding:.15rem 0 .15rem 1.5rem;position:relative;color:var(--text)}
      .holo-tl-bullets li::before{
        content:'';position:absolute;left:0;top:.55rem;width:8px;height:3px;border-radius:1px;
        background:var(--holo-grad);
      }

      /* Project cards */
      .holo-proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:2px}
      .holo-proj{position:relative;border-radius:14px;padding:2px;background:linear-gradient(135deg,rgba(255,107,255,0.1),rgba(0,229,255,0.1),rgba(0,255,136,0.1));transition:all .3s}
      .holo-proj:hover{background:var(--border-holo)}
      .holo-proj-inner{
        background:var(--bg);border-radius:12px;padding:1.3rem;height:100%;
      }
      .holo-proj h3{font-size:.95rem;font-weight:700;color:var(--bright)}
      .holo-proj .ptype{font-size:.75rem;color:var(--holo-2)}
      .holo-proj .plink{font-size:.7rem;font-family:'JetBrains Mono',monospace;margin:.2rem 0}
      .holo-proj .plink a{color:var(--dim);text-decoration:none}
      .holo-proj .plink a:hover{color:var(--holo-1)}
      .holo-proj p{font-size:.8rem;color:var(--dim);margin-top:.2rem;line-height:1.5}
      .holo-proj .ptags{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.5rem}
      .holo-proj .ptags span{font-size:.65rem;padding:.15rem .4rem;border-radius:999px;background:rgba(255,107,255,0.06);color:var(--holo-1);border:1px solid rgba(255,107,255,0.1)}

      /* Info */
      .holo-info-row{display:flex;flex-wrap:wrap;gap:2.5rem}
      .holo-info h3{font-size:1rem;font-weight:700;color:var(--bright)}
      .holo-info p{font-size:.88rem;color:var(--holo-2)}

      .holo-langs{display:flex;flex-wrap:wrap;gap:1rem}
      .holo-lang .name{font-weight:600;color:var(--bright);font-size:.95rem}
      .holo-lang .level{font-size:.75rem;color:var(--dim);margin-left:.3rem}

      /* Footer */
      .holo-footer{
        margin-top:2rem;position:relative;border-radius:16px;padding:2px;
        background:linear-gradient(135deg,rgba(255,107,255,0.15),rgba(0,229,255,0.15),rgba(0,255,136,0.15));
      }
      .holo-footer-inner{
        background:var(--bg);border-radius:14px;padding:1.5rem 2rem;
        display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem;
      }
      .holo-footer p{font-size:.85rem;color:var(--dim)}
      .holo-footer a{color:var(--holo-1);text-decoration:none;font-weight:600}
      .holo-footer-links{display:flex;gap:1.5rem}
      .holo-footer-links a{font-size:.8rem;color:var(--dim);font-weight:400;text-decoration:none}
      .holo-footer-links a:hover{color:var(--holo-2)}

      @media(max-width:640px){
        .holo-hero .holo-card-inner{padding:2.5rem 1.5rem}
        .stat-row{grid-template-columns:repeat(2,1fr)}
        .holo-tl-header{flex-direction:column}
        .holo-proj-grid{grid-template-columns:1fr}
      }

      @media print{
        body::before,body::after{display:none}
        body{background:#fff;color:#1a1a1a}
        .holo-card{background:none;padding:0}
        .holo-card-inner{background:#fff;border:1px solid #e5e7eb;backdrop-filter:none}
        .holo-card-inner::before{display:none}
        .back-link,.holo-badge{display:none}
        .holo-hero h1{-webkit-text-fill-color:#1a1a1a}
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
