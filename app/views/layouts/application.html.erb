<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Senior Software Engineer | 12+ Years Experience</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Senior Software Engineer with 12+ years specializing in back-end systems, database optimization, performance engineering, and application security. Based in Warsaw, Poland. Available for new opportunities.">
    <meta name="keywords" content="Senior Software Engineer, Back-End Developer, Database Expert, Performance Optimization, Application Security, API Development, Ruby on Rails, PostgreSQL, Redis, Docker, AWS, Warsaw Poland">
    <meta name="author" content="Abdulla Achilov">
    <meta name="robots" content="index, follow">

    <!-- Open Graph -->
    <meta property="og:title" content="Abdulla Achilov | Senior Software Engineer">
    <meta property="og:description" content="12+ years specializing in back-end systems, database optimization, performance, and security. Open to new opportunities.">
    <meta property="og:type" content="profile">
    <meta property="og:url" content="https://abdullaachilov.com">
    <meta property="profile:first_name" content="Abdulla">
    <meta property="profile:last_name" content="Achilov">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="Abdulla Achilov | Senior Software Engineer">
    <meta name="twitter:description" content="12+ years specializing in back-end systems, databases, performance, and security. Open to opportunities.">

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><polygon points='50,5 95,35 80,90 20,90 5,35' fill='%23CC342D'/><polygon points='50,5 95,35 50,50 5,35' fill='%23E8524A' opacity='0.8'/><polygon points='50,50 95,35 80,90' fill='%23A8201A' opacity='0.7'/><polygon points='50,50 5,35 20,90' fill='%23B82A22' opacity='0.75'/><polygon points='50,50 20,90 80,90' fill='%239B1B14' opacity='0.65'/></svg>">

    <!-- Prevent dark mode FOUC -->
    <script>
      (function(){
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="canonical" href="https://abdullaachilov.com">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Abdulla Achilov",
      "jobTitle": "Senior Software Engineer",
      "url": "https://abdullaachilov.com",
      "sameAs": [
        "https://github.com/abdullaachilov",
        "https://www.linkedin.com/in/abdulla-achilov-aa4260183/",
        "https://www.toptal.com/resume/abdulla-achilov",
        "https://t.me/abdullaachilov"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Warsaw",
        "addressCountry": "PL"
      },
      "knowsAbout": ["Ruby on Rails", "PostgreSQL", "Redis", "Docker", "AWS", "GraphQL", "Elasticsearch", "CI/CD"],
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Moscow Technical University of Communications and Informatics"
      },
      "worksFor": {
        "@type": "Organization",
        "name": "Crosslake Technologies"
      }
    }
    </script>

    <!-- Analytics: Umami (self-hosted on Railway) -->
    <!-- After logging into Umami, add your site and replace WEBSITE_ID below, then uncomment -->
    <!-- <script defer src="https://umami-production-f70a9.up.railway.app/script.js" data-website-id="WEBSITE_ID"></script> -->
  </head>

  <body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 antialiased transition-colors duration-200">
    <!-- Floating toolbar -->
    <div class="fixed top-4 right-4 flex gap-2 z-50 print:hidden">
      <button onclick="toggleDark()" aria-label="Toggle dark mode"
        class="p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-all text-gray-600 dark:text-gray-300 cursor-pointer">
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <button onclick="window.print()" aria-label="Save as PDF"
        class="p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-all text-gray-600 dark:text-gray-300 cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M6 20h12a2 2 0 002-2V8l-6-6H6a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </button>
    </div>

    <%= yield %>

    <script>
      function toggleDark() {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      }
    </script>
  </body>
</html>
