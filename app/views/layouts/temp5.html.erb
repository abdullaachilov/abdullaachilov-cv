<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Command Center</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='8' fill='%230a0f1c'/><circle cx='50' cy='50' r='30' fill='none' stroke='%2300ff88' stroke-width='2'/><circle cx='50' cy='50' r='4' fill='%2300ff88'/></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');

      *{margin:0;padding:0;box-sizing:border-box}

      :root{
        --bg:#070b14;
        --bg2:#0c1220;
        --bg3:#111827;
        --card:rgba(17,24,39,0.8);
        --border:rgba(56,189,248,0.12);
        --border-h:rgba(56,189,248,0.3);
        --cyan:#38bdf8;
        --green:#22c55e;
        --emerald:#10b981;
        --amber:#f59e0b;
        --rose:#f43f5e;
        --purple:#a78bfa;
        --text:#e2e8f0;
        --dim:#64748b;
        --bright:#f8fafc;
        --glow-c:0 0 30px rgba(56,189,248,0.15);
        --glow-g:0 0 30px rgba(34,197,94,0.15);
      }

      body{
        font-family:'Inter',sans-serif;
        background:var(--bg);
        color:var(--text);
        line-height:1.6;
        overflow-x:hidden;
      }

      /* Subtle grid bg */
      body::before{
        content:'';position:fixed;inset:0;
        background-image:
          linear-gradient(rgba(56,189,248,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(56,189,248,0.03) 1px, transparent 1px);
        background-size:40px 40px;
        z-index:0;pointer-events:none;
      }

      .cc-page{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:1.5rem 1.5rem 4rem}

      .back-link{display:inline-block;font-size:.75rem;color:var(--dim);text-decoration:none;margin-bottom:1.5rem;font-family:'JetBrains Mono',monospace}
      .back-link:hover{color:var(--cyan)}

      /* Status bar */
      .status-bar{
        display:flex;flex-wrap:wrap;align-items:center;gap:1rem;
        padding:.6rem 1.2rem;
        background:var(--bg2);border:1px solid var(--border);border-radius:8px;
        margin-bottom:2rem;font-family:'JetBrains Mono',monospace;font-size:.7rem;
      }
      .status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px rgba(34,197,94,0.6);animation:pulse-dot 2s ease infinite}
      @keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}
      .status-text{color:var(--green)}
      .status-sep{color:var(--dim)}
      .status-label{color:var(--dim)}
      .status-val{color:var(--cyan)}

      /* Hero */
      .cc-hero{
        background:var(--card);border:1px solid var(--border);border-radius:12px;
        padding:3rem;margin-bottom:2rem;position:relative;overflow:hidden;
        backdrop-filter:blur(20px);
      }
      .cc-hero::before{
        content:'';position:absolute;top:0;left:0;right:0;height:1px;
        background:linear-gradient(90deg,transparent,var(--cyan),transparent);
      }
      .cc-hero::after{
        content:'';position:absolute;inset:0;
        background:radial-gradient(ellipse at 70% 0%,rgba(56,189,248,0.06),transparent 60%);
        pointer-events:none;
      }

      .cc-hero h1{
        font-size:clamp(2.5rem,5vw,4rem);font-weight:900;letter-spacing:-.03em;
        color:var(--bright);line-height:1.1;margin-bottom:.4rem;
      }
      .cc-hero .title{font-size:1.1rem;font-weight:600;color:var(--cyan);margin-bottom:.2rem}
      .cc-hero .sub{font-size:.8rem;color:var(--dim);font-family:'JetBrains Mono',monospace;letter-spacing:.05em}
      .cc-hero .loc{font-size:.85rem;color:var(--dim);margin-top:.2rem}

      .cc-contacts{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1.5rem}
      .cc-contacts a{
        font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--text);
        text-decoration:none;padding:.45rem .9rem;
        background:rgba(56,189,248,0.06);border:1px solid var(--border);border-radius:6px;
        transition:all .25s;
      }
      .cc-contacts a:hover{border-color:var(--cyan);color:var(--cyan);box-shadow:var(--glow-c)}

      /* KPI row */
      .kpi-row{
        display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;
        margin-bottom:2rem;
      }
      .kpi{
        background:var(--card);border:1px solid var(--border);border-radius:10px;
        padding:1.5rem;text-align:center;position:relative;overflow:hidden;
        backdrop-filter:blur(10px);
      }
      .kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
      .kpi:nth-child(1)::before{background:var(--cyan)}
      .kpi:nth-child(2)::before{background:var(--green)}
      .kpi:nth-child(3)::before{background:var(--amber)}
      .kpi:nth-child(4)::before{background:var(--rose)}

      .kpi-num{
        font-size:2.2rem;font-weight:900;line-height:1;margin-bottom:.3rem;
        font-family:'JetBrains Mono',monospace;
      }
      .kpi:nth-child(1) .kpi-num{color:var(--cyan)}
      .kpi:nth-child(2) .kpi-num{color:var(--green)}
      .kpi:nth-child(3) .kpi-num{color:var(--amber)}
      .kpi:nth-child(4) .kpi-num{color:var(--rose)}

      .kpi-label{font-size:.7rem;color:var(--dim);text-transform:uppercase;letter-spacing:.15em;font-weight:600}
      .kpi-sub{font-size:.75rem;color:var(--dim);margin-top:.2rem}

      /* Section card */
      .cc-card{
        background:var(--card);border:1px solid var(--border);border-radius:12px;
        padding:2rem;margin-bottom:1.5rem;position:relative;overflow:hidden;
        backdrop-filter:blur(20px);
      }
      .cc-card::before{
        content:'';position:absolute;top:0;left:0;right:0;height:1px;
        background:linear-gradient(90deg,transparent,var(--border-h),transparent);
      }

      .cc-label{
        font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;
        color:var(--cyan);margin-bottom:1.5rem;
        display:flex;align-items:center;gap:.5rem;
      }
      .cc-label::before{content:'';width:16px;height:2px;background:var(--cyan);border-radius:1px}

      /* Skills as bars */
      .skill-row{display:flex;align-items:center;gap:.8rem;padding:.3rem 0}
      .skill-name{min-width:130px;font-size:.8rem;color:var(--text);font-weight:500}
      .skill-track{flex:1;height:6px;background:var(--bg);border-radius:3px;overflow:hidden}
      .skill-fill{height:100%;border-radius:3px;transition:width 1s ease}
      .sf-cyan{background:linear-gradient(90deg,var(--cyan),#0ea5e9)}
      .sf-green{background:linear-gradient(90deg,var(--green),var(--emerald))}
      .sf-amber{background:linear-gradient(90deg,var(--amber),#eab308)}
      .sf-purple{background:linear-gradient(90deg,var(--purple),#8b5cf6)}

      /* Timeline */
      .tl-item{
        display:grid;grid-template-columns:1fr auto;gap:1rem;
        padding:1.2rem 0;border-bottom:1px solid rgba(56,189,248,0.06);
      }
      .tl-item:last-child{border-bottom:none}
      .tl-role{font-size:1rem;font-weight:700;color:var(--bright)}
      .tl-company{color:var(--cyan);font-weight:500}
      .tl-date{font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--dim);white-space:nowrap;text-align:right}
      .tl-bullets{list-style:none;padding:0;margin-top:.4rem}
      .tl-bullets li{font-size:.85rem;color:var(--text);padding:.15rem 0 .15rem 1.2rem;position:relative}
      .tl-bullets li::before{
        content:'';position:absolute;left:0;top:.55rem;
        width:6px;height:6px;border-radius:50%;border:1.5px solid var(--cyan);
      }

      /* Impact tag inline */
      .impact{
        display:inline-block;font-family:'JetBrains Mono',monospace;
        font-size:.7rem;font-weight:600;padding:.1rem .4rem;border-radius:3px;
        margin-left:.3rem;
      }
      .impact-up{background:rgba(34,197,94,0.12);color:var(--green)}
      .impact-down{background:rgba(56,189,248,0.12);color:var(--cyan)}

      /* Project grid */
      .proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
      .proj{
        background:rgba(15,23,42,0.6);border:1px solid var(--border);border-radius:10px;
        padding:1.3rem;transition:all .3s;position:relative;overflow:hidden;
      }
      .proj::after{
        content:'';position:absolute;inset:0;border-radius:10px;
        opacity:0;transition:opacity .3s;
        background:radial-gradient(circle at 50% 0%,rgba(56,189,248,0.06),transparent 70%);
      }
      .proj:hover{border-color:var(--border-h);transform:translateY(-2px);box-shadow:var(--glow-c)}
      .proj:hover::after{opacity:1}

      .proj h3{font-size:.95rem;font-weight:700;color:var(--bright);position:relative;z-index:1}
      .proj .ptype{font-size:.75rem;color:var(--cyan);position:relative;z-index:1}
      .proj .plink{font-size:.7rem;font-family:'JetBrains Mono',monospace;margin:.2rem 0;position:relative;z-index:1}
      .proj .plink a{color:var(--dim);text-decoration:none;transition:color .2s}
      .proj .plink a:hover{color:var(--cyan)}
      .proj p{font-size:.8rem;color:var(--dim);line-height:1.5;position:relative;z-index:1}
      .proj .ptags{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.5rem;position:relative;z-index:1}
      .proj .ptags span{
        font-family:'JetBrains Mono',monospace;font-size:.65rem;
        padding:.15rem .4rem;border-radius:4px;
        background:rgba(56,189,248,0.06);color:var(--cyan);border:1px solid rgba(56,189,248,0.1);
      }

      /* Info */
      .info-flex{display:flex;flex-wrap:wrap;gap:2rem}
      .info-block h3{font-size:1rem;font-weight:700;color:var(--bright)}
      .info-block p{font-size:.88rem;color:var(--cyan)}

      .lang-pills{display:flex;flex-wrap:wrap;gap:.5rem}
      .lang-pill{
        padding:.4rem 1rem;border:1px solid var(--border);border-radius:6px;
        font-size:.85rem;font-weight:500;color:var(--text);
        background:rgba(56,189,248,0.04);
      }
      .lang-pill .lv{font-weight:400;color:var(--dim);font-size:.75rem;margin-left:.3rem}

      /* Footer */
      .cc-footer{
        margin-top:2rem;padding:1.5rem 2rem;
        background:var(--card);border:1px solid var(--border);border-radius:10px;
        display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem;
      }
      .cc-footer p{font-size:.85rem;color:var(--dim)}
      .cc-footer a{color:var(--cyan);text-decoration:none;font-weight:600}
      .cc-footer a:hover{text-shadow:0 0 10px rgba(56,189,248,0.5)}
      .cc-footer-links{display:flex;gap:1.5rem}
      .cc-footer-links a{font-size:.8rem;color:var(--dim);font-weight:400}
      .cc-footer-links a:hover{color:var(--cyan)}

      @media(max-width:768px){
        .cc-hero{padding:2rem}
        .tl-item{grid-template-columns:1fr;gap:.3rem}
        .tl-date{text-align:left}
        .kpi-row{grid-template-columns:repeat(2,1fr)}
        .proj-grid{grid-template-columns:1fr}
      }

      @media print{
        body::before{display:none}
        body{background:#fff;color:#1a1a1a}
        .cc-card,.cc-hero,.kpi,.cc-footer{background:#fff;border-color:#e5e7eb;backdrop-filter:none}
        .cc-card::before,.cc-hero::before{display:none}
        .back-link,.status-bar{display:none}
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
