<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Neo-Brutalist CV</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23FF5722'/><text x='50' y='70' text-anchor='middle' font-size='60' fill='white' font-weight='bold'>A</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;700;900&display=swap');

      * { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --black: #1a1a1a;
        --white: #fafaf5;
        --yellow: #ffe600;
        --pink: #ff3366;
        --blue: #3344ff;
        --green: #00cc88;
        --orange: #ff6b00;
        --border: 3px solid var(--black);
        --shadow: 6px 6px 0 var(--black);
        --shadow-hover: 8px 8px 0 var(--black);
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--white);
        color: var(--black);
        line-height: 1.5;
      }

      .page { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

      .back-link {
        display: inline-block;
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--black);
        text-decoration: none;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid var(--black);
      }

      .badge {
        display: inline-block;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        padding: 0.3rem 0.7rem;
        background: var(--pink);
        color: white;
        border: var(--border);
        box-shadow: 3px 3px 0 var(--black);
        margin-bottom: 1rem;
      }

      /* Hero */
      .hero-brutal {
        background: var(--yellow);
        border: var(--border);
        box-shadow: var(--shadow);
        padding: 3rem 2.5rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
      }

      .hero-brutal::after {
        content: 'CV';
        position: absolute;
        right: -20px;
        bottom: -30px;
        font-size: 12rem;
        font-weight: 900;
        opacity: 0.08;
        line-height: 1;
        pointer-events: none;
      }

      .hero-brutal h1 {
        font-size: clamp(2.5rem, 7vw, 4.5rem);
        font-weight: 900;
        line-height: 1;
        text-transform: uppercase;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
      }

      .hero-brutal .title {
        font-family: 'Space Mono', monospace;
        font-size: 1.1rem;
        background: var(--black);
        color: var(--yellow);
        display: inline-block;
        padding: 0.3rem 0.8rem;
        margin-bottom: 0.5rem;
      }

      .hero-brutal .sub {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--black);
        opacity: 0.7;
      }

      .hero-brutal .location {
        font-size: 0.95rem;
        margin-top: 0.3rem;
      }

      .contact-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1.5rem;
      }

      .contact-strip a {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--black);
        text-decoration: none;
        padding: 0.4rem 0.8rem;
        background: var(--white);
        border: 2px solid var(--black);
        box-shadow: 3px 3px 0 var(--black);
        transition: all 0.1s;
      }

      .contact-strip a:hover {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0 var(--black);
      }

      /* Section */
      .brutal-section {
        border: var(--border);
        box-shadow: var(--shadow);
        margin-bottom: 2rem;
        background: white;
      }

      .brutal-section-head {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        padding: 0.8rem 1.5rem;
        border-bottom: var(--border);
        font-weight: 700;
      }

      .s-blue .brutal-section-head { background: var(--blue); color: white; }
      .s-pink .brutal-section-head { background: var(--pink); color: white; }
      .s-green .brutal-section-head { background: var(--green); color: var(--black); }
      .s-orange .brutal-section-head { background: var(--orange); color: white; }
      .s-yellow .brutal-section-head { background: var(--yellow); color: var(--black); }
      .s-black .brutal-section-head { background: var(--black); color: white; }

      .brutal-section-body { padding: 1.5rem; }

      /* Summary */
      .summary-text {
        font-size: 1.1rem;
        line-height: 1.7;
      }

      .summary-text strong {
        background: var(--yellow);
        padding: 0 0.2rem;
      }

      /* Skills */
      .skills-brutal {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .skill-chip {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        padding: 0.4rem 0.8rem;
        border: 2px solid var(--black);
        background: white;
        transition: all 0.1s;
        cursor: default;
      }

      .skill-chip:nth-child(4n+1) { background: #ffe600; }
      .skill-chip:nth-child(4n+2) { background: #ff3366; color: white; }
      .skill-chip:nth-child(4n+3) { background: #00cc88; }
      .skill-chip:nth-child(4n) { background: #3344ff; color: white; }

      .skill-chip:hover {
        transform: rotate(-2deg) scale(1.05);
        box-shadow: 3px 3px 0 var(--black);
      }

      /* Experience */
      .exp-item {
        padding: 1.2rem 0;
        border-bottom: 2px dashed var(--black);
      }

      .exp-item:last-child { border-bottom: none; }

      .exp-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
      }

      .exp-role {
        font-size: 1.1rem;
        font-weight: 900;
        text-transform: uppercase;
      }

      .exp-company {
        font-weight: 400;
        text-transform: none;
        color: var(--blue);
      }

      .exp-date {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        background: var(--black);
        color: white;
        padding: 0.2rem 0.5rem;
      }

      .exp-bullets {
        list-style: none;
        padding: 0;
      }

      .exp-bullets li {
        font-size: 0.9rem;
        padding: 0.2rem 0 0.2rem 1.5rem;
        position: relative;
      }

      .exp-bullets li::before {
        content: '\2588';
        position: absolute;
        left: 0;
        color: var(--pink);
        font-size: 0.7rem;
      }

      /* Projects */
      .projects-brutal {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
      }

      .project-brutal {
        border: 2px solid var(--black);
        padding: 1.2rem;
        background: white;
        transition: all 0.15s;
        position: relative;
      }

      .project-brutal:nth-child(1) { border-left: 8px solid var(--yellow); }
      .project-brutal:nth-child(2) { border-left: 8px solid var(--pink); }
      .project-brutal:nth-child(3) { border-left: 8px solid var(--blue); }
      .project-brutal:nth-child(4) { border-left: 8px solid var(--green); }

      .project-brutal:hover {
        transform: translate(-3px, -3px);
        box-shadow: 6px 6px 0 var(--black);
      }

      .project-brutal h3 {
        font-size: 1.1rem;
        font-weight: 900;
        text-transform: uppercase;
      }

      .project-brutal .ptype {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        color: var(--blue);
      }

      .project-brutal .plink {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        margin: 0.3rem 0;
      }

      .project-brutal .plink a {
        color: var(--black);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .project-brutal p {
        font-size: 0.85rem;
        color: #555;
        margin-top: 0.3rem;
      }

      .project-brutal .ptags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-top: 0.5rem;
      }

      .project-brutal .ptags span {
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        padding: 0.15rem 0.4rem;
        border: 1px solid var(--black);
        text-transform: uppercase;
      }

      /* Info row */
      .info-brutal {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
      }

      .info-brutal h3 {
        font-weight: 900;
        font-size: 1rem;
        text-transform: uppercase;
      }

      .info-brutal .sub { color: var(--blue); font-size: 0.9rem; }

      .lang-brutal {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
      }

      .lang-brutal .lang-b {
        padding: 0.4rem 0.8rem;
        border: 2px solid var(--black);
        font-weight: 700;
      }

      .lang-brutal .lang-b .lv {
        font-family: 'Space Mono', monospace;
        font-weight: 400;
        font-size: 0.8rem;
        color: #666;
      }

      /* Footer */
      .footer-brutal {
        margin-top: 2rem;
        padding: 1.5rem;
        border: var(--border);
        background: var(--black);
        color: var(--white);
        box-shadow: var(--shadow);
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .footer-brutal p { font-size: 0.9rem; }

      .footer-brutal a {
        color: var(--yellow);
        text-decoration: none;
        font-weight: 700;
      }

      .footer-brutal-links {
        display: flex;
        gap: 1rem;
      }

      .footer-brutal-links a {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--white);
        text-decoration: none;
        border-bottom: 2px solid var(--yellow);
        padding-bottom: 2px;
      }

      @media (max-width: 640px) {
        .hero-brutal { padding: 2rem 1.5rem; }
        .exp-header { flex-direction: column; }
        .projects-brutal { grid-template-columns: 1fr; }
      }

      @media print {
        .badge, .back-link { display: none; }
        .brutal-section, .hero-brutal, .footer-brutal { box-shadow: none; }
        body { background: white; }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
