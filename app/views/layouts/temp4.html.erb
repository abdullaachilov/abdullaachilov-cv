<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Vaporwave CV</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23120025'/><text x='50' y='65' text-anchor='middle' font-size='50' fill='%23ff00ff'>A</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap');

      * { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --bg: #0a001a;
        --neon-pink: #ff00ff;
        --neon-blue: #00ffff;
        --neon-purple: #b347d9;
        --hot-pink: #ff3399;
        --text: #e0d0ff;
        --text-dim: #7a6899;
        --card-bg: rgba(20, 0, 50, 0.7);
        --border: rgba(180, 0, 255, 0.2);
        --glow-pink: 0 0 20px rgba(255,0,255,0.3), 0 0 60px rgba(255,0,255,0.1);
        --glow-blue: 0 0 20px rgba(0,255,255,0.3), 0 0 60px rgba(0,255,255,0.1);
      }

      body {
        font-family: 'Rajdhani', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        overflow-x: hidden;
        position: relative;
      }

      /* Retro grid floor */
      body::before {
        content: '';
        position: fixed;
        bottom: 0;
        left: -50%;
        right: -50%;
        height: 50vh;
        background:
          linear-gradient(0deg, var(--neon-pink) 1px, transparent 1px),
          linear-gradient(90deg, var(--neon-pink) 1px, transparent 1px);
        background-size: 60px 40px;
        transform: perspective(500px) rotateX(60deg);
        transform-origin: bottom;
        opacity: 0.12;
        z-index: 0;
        animation: gridScroll 4s linear infinite;
      }

      @keyframes gridScroll {
        from { background-position: 0 0; }
        to { background-position: 0 40px; }
      }

      /* Sun */
      body::after {
        content: '';
        position: fixed;
        bottom: 30vh;
        left: 50%;
        transform: translateX(-50%);
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: linear-gradient(to bottom, #ff6600, #ff0066, #cc00ff);
        opacity: 0.08;
        z-index: 0;
        filter: blur(2px);
        mask-image: repeating-linear-gradient(
          to bottom,
          black 0px, black 8px,
          transparent 8px, transparent 12px
        );
        -webkit-mask-image: repeating-linear-gradient(
          to bottom,
          black 0px, black 8px,
          transparent 8px, transparent 12px
        );
      }

      .vapor-page {
        position: relative;
        z-index: 1;
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      .back-link {
        display: inline-block;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem;
        color: var(--text-dim);
        text-decoration: none;
        margin-bottom: 1.5rem;
        letter-spacing: 0.1em;
      }

      .back-link:hover { color: var(--neon-blue); }

      .badge {
        display: inline-block;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        padding: 0.3rem 0.8rem;
        border: 1px solid var(--neon-pink);
        color: var(--neon-pink);
        box-shadow: var(--glow-pink);
        margin-bottom: 1rem;
      }

      /* Hero */
      .vapor-hero {
        text-align: center;
        padding: 4rem 2rem 3rem;
        margin-bottom: 2rem;
        position: relative;
      }

      .vapor-hero h1 {
        font-family: 'Orbitron', sans-serif;
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        background: linear-gradient(180deg, var(--neon-blue), var(--neon-pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
        filter: drop-shadow(0 0 20px rgba(255,0,255,0.3));
        margin-bottom: 0.5rem;
      }

      .vapor-hero .title {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--neon-blue);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        text-shadow: 0 0 10px rgba(0,255,255,0.5);
      }

      .vapor-hero .sub {
        font-size: 0.8rem;
        color: var(--text-dim);
        letter-spacing: 0.1em;
        margin-top: 0.3rem;
      }

      .vapor-hero .location {
        font-size: 0.85rem;
        color: var(--text-dim);
        margin-top: 0.3rem;
      }

      .vapor-links {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.5rem;
      }

      .vapor-links a {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        color: var(--text);
        text-decoration: none;
        padding: 0.4rem 0.9rem;
        border: 1px solid var(--border);
        transition: all 0.3s;
      }

      .vapor-links a:hover {
        color: var(--neon-pink);
        border-color: var(--neon-pink);
        box-shadow: var(--glow-pink);
      }

      /* Neon divider */
      .neon-divider {
        height: 2px;
        margin: 2rem 0;
        background: linear-gradient(90deg, transparent, var(--neon-pink), var(--neon-blue), transparent);
        box-shadow: 0 0 10px rgba(255,0,255,0.3);
      }

      /* Section */
      .vapor-section { margin-bottom: 2rem; }

      .vapor-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 2px;
        padding: 2rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .vapor-label {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--neon-pink);
        margin-bottom: 1.5rem;
        text-shadow: 0 0 10px rgba(255,0,255,0.5);
      }

      /* Summary */
      .vapor-summary {
        font-size: 1rem;
        line-height: 1.8;
        font-weight: 400;
      }

      .vapor-summary strong {
        color: var(--neon-blue);
        font-weight: 600;
        text-shadow: 0 0 8px rgba(0,255,255,0.3);
      }

      /* Skills */
      .vapor-skills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .vapor-skill {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem;
        padding: 0.35rem 0.75rem;
        border: 1px solid var(--border);
        color: var(--text);
        transition: all 0.3s;
        letter-spacing: 0.03em;
      }

      .vapor-skill:nth-child(3n+1):hover {
        border-color: var(--neon-pink);
        color: var(--neon-pink);
        box-shadow: var(--glow-pink);
      }

      .vapor-skill:nth-child(3n+2):hover {
        border-color: var(--neon-blue);
        color: var(--neon-blue);
        box-shadow: var(--glow-blue);
      }

      .vapor-skill:nth-child(3n):hover {
        border-color: var(--neon-purple);
        color: var(--neon-purple);
        box-shadow: 0 0 20px rgba(180,70,220,0.3);
      }

      /* Experience */
      .vapor-exp-item {
        padding: 1.2rem 0;
        border-bottom: 1px solid var(--border);
      }

      .vapor-exp-item:last-child { border-bottom: none; }

      .vapor-exp-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
      }

      .vapor-exp-role {
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
      }

      .vapor-exp-company {
        color: var(--neon-blue);
        font-weight: 400;
        text-shadow: 0 0 8px rgba(0,255,255,0.3);
      }

      .vapor-exp-date {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem;
        color: var(--neon-pink);
        letter-spacing: 0.05em;
      }

      .vapor-exp-bullets {
        list-style: none;
        padding: 0;
      }

      .vapor-exp-bullets li {
        font-size: 0.88rem;
        padding: 0.2rem 0 0.2rem 1.5rem;
        position: relative;
      }

      .vapor-exp-bullets li::before {
        content: '//';
        position: absolute;
        left: 0;
        color: var(--neon-pink);
        font-family: 'Orbitron', sans-serif;
        font-size: 0.65rem;
        opacity: 0.7;
      }

      /* Projects */
      .vapor-projects {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 1rem;
      }

      .vapor-project {
        border: 1px solid var(--border);
        padding: 1.3rem;
        background: rgba(20,0,50,0.5);
        transition: all 0.3s;
        position: relative;
      }

      .vapor-project:hover {
        border-color: var(--neon-pink);
        box-shadow: var(--glow-pink);
      }

      .vapor-project h3 {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .vapor-project .ptype {
        font-size: 0.75rem;
        color: var(--neon-blue);
      }

      .vapor-project .plink {
        font-size: 0.75rem;
        margin: 0.3rem 0;
      }

      .vapor-project .plink a {
        color: var(--neon-pink);
        text-decoration: none;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.65rem;
      }

      .vapor-project .plink a:hover { text-shadow: 0 0 8px rgba(255,0,255,0.5); }

      .vapor-project p {
        font-size: 0.82rem;
        color: var(--text-dim);
        margin-top: 0.3rem;
      }

      .vapor-project .ptags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.6rem;
      }

      .vapor-project .ptags span {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.6rem;
        padding: 0.2rem 0.4rem;
        border: 1px solid rgba(180,0,255,0.2);
        color: var(--neon-purple);
        letter-spacing: 0.03em;
      }

      /* Education & Languages */
      .vapor-edu h3 {
        font-weight: 700;
        color: #fff;
        font-size: 1rem;
      }

      .vapor-edu p {
        color: var(--neon-blue);
        font-size: 0.9rem;
      }

      .vapor-langs {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }

      .vapor-lang .name {
        font-weight: 700;
        color: #fff;
      }

      .vapor-lang .level {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem;
        color: var(--text-dim);
        margin-left: 0.3rem;
      }

      /* Footer */
      .vapor-footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .vapor-footer p {
        font-size: 0.85rem;
        color: var(--text-dim);
      }

      .vapor-footer a {
        color: var(--neon-pink);
        text-decoration: none;
      }

      .vapor-footer a:hover { text-shadow: 0 0 8px rgba(255,0,255,0.5); }

      .vapor-footer-links {
        display: flex;
        gap: 1.5rem;
      }

      .vapor-footer-links a {
        font-size: 0.8rem;
        color: var(--text-dim);
        text-decoration: none;
      }

      .vapor-footer-links a:hover { color: var(--neon-blue); }

      @media (max-width: 640px) {
        .vapor-hero { padding: 3rem 1rem 2rem; }
        .vapor-card { padding: 1.5rem; }
        .vapor-exp-header { flex-direction: column; }
        .vapor-projects { grid-template-columns: 1fr; }
      }

      @media print {
        body::before, body::after { display: none; }
        body { background: white; color: #333; }
        .vapor-card { background: white; border: 1px solid #ddd; backdrop-filter: none; }
        .back-link, .badge { display: none; }
        .vapor-hero h1 { -webkit-text-fill-color: #333; }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
