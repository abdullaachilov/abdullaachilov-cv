<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Blueprint</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23062040'/><line x1='10' y1='50' x2='90' y2='50' stroke='%234aa3df' stroke-width='1'/><line x1='50' y1='10' x2='50' y2='90' stroke='%234aa3df' stroke-width='1'/><circle cx='50' cy='50' r='20' fill='none' stroke='%234aa3df' stroke-width='1.5'/></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap');

      *{margin:0;padding:0;box-sizing:border-box}

      :root{
        --bg:#062040;
        --bg2:#0a2a52;
        --blue:#4aa3df;
        --blue-dim:#2b6a9e;
        --blue-glow:rgba(74,163,223,0.2);
        --white:#e8f0f8;
        --dim:#5a8ab5;
        --line:rgba(74,163,223,0.15);
        --line-bright:rgba(74,163,223,0.35);
        --mono:'IBM Plex Mono',monospace;
        --sans:'IBM Plex Sans',sans-serif;
      }

      body{
        font-family:var(--sans);background:var(--bg);color:var(--white);line-height:1.6;
      }

      /* Blueprint grid */
      body::before{
        content:'';position:fixed;inset:0;
        background:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px),
          linear-gradient(rgba(74,163,223,0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(74,163,223,0.06) 1px, transparent 1px);
        background-size:80px 80px, 80px 80px, 16px 16px, 16px 16px;
        z-index:0;pointer-events:none;
      }

      .bp-page{position:relative;z-index:1;max-width:920px;margin:0 auto;padding:2rem 2rem 4rem}

      .back-link{display:inline-block;font-family:var(--mono);font-size:.72rem;color:var(--dim);text-decoration:none;margin-bottom:1.5rem}
      .back-link:hover{color:var(--blue)}

      /* Technical label */
      .bp-tech-label{
        font-family:var(--mono);font-size:.6rem;color:var(--dim);
        letter-spacing:.2em;text-transform:uppercase;
        display:flex;align-items:center;gap:.5rem;
      }
      .bp-tech-label::before{content:'[';color:var(--blue)}
      .bp-tech-label::after{content:']';color:var(--blue)}

      /* Hero */
      .bp-hero{
        border:1px solid var(--line-bright);padding:3rem;margin-bottom:2rem;
        position:relative;
      }
      /* Corner marks */
      .bp-hero::before,.bp-hero::after{
        content:'';position:absolute;width:20px;height:20px;
        border-color:var(--blue);border-style:solid;
      }
      .bp-hero::before{top:-1px;left:-1px;border-width:2px 0 0 2px}
      .bp-hero::after{bottom:-1px;right:-1px;border-width:0 2px 2px 0}

      .bp-hero h1{
        font-family:var(--mono);font-size:clamp(2rem,5vw,3.2rem);
        font-weight:700;letter-spacing:.02em;text-transform:uppercase;
        color:var(--white);margin:.5rem 0;
      }

      .bp-hero .title{
        font-size:1rem;font-weight:600;color:var(--blue);
        text-transform:uppercase;letter-spacing:.1em;
      }

      .bp-hero .sub{
        font-family:var(--mono);font-size:.72rem;color:var(--dim);
        letter-spacing:.05em;margin-top:.2rem;
      }

      .bp-hero .loc{
        font-family:var(--mono);font-size:.8rem;color:var(--dim);margin-top:.2rem;
      }

      .bp-hero .spec-line{
        font-family:var(--mono);font-size:.65rem;color:var(--dim);
        margin-top:1rem;padding-top:.8rem;
        border-top:1px dashed var(--line);
      }
      .bp-hero .spec-line span{color:var(--blue)}

      .bp-contacts{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1rem}
      .bp-contacts a{
        font-family:var(--mono);font-size:.72rem;color:var(--dim);
        text-decoration:none;padding:.4rem .8rem;
        border:1px dashed var(--line-bright);
        transition:all .3s;
      }
      .bp-contacts a:hover{color:var(--blue);border-color:var(--blue);border-style:solid;box-shadow:0 0 15px var(--blue-glow)}

      /* Section */
      .bp-section{
        border:1px solid var(--line);padding:1.8rem;margin-bottom:1.5rem;
        position:relative;
      }
      .bp-section::before{
        content:attr(data-ref);position:absolute;top:-.5rem;left:1rem;
        font-family:var(--mono);font-size:.6rem;color:var(--blue);
        background:var(--bg);padding:0 .5rem;letter-spacing:.1em;
      }

      .bp-label{
        font-family:var(--mono);font-size:.6rem;font-weight:600;
        text-transform:uppercase;letter-spacing:.2em;color:var(--blue);
        margin-bottom:1.2rem;
        padding-bottom:.5rem;border-bottom:1px dashed var(--line);
      }

      /* Summary */
      .bp-summary{font-size:.95rem;line-height:1.8;color:var(--white)}
      .bp-summary strong{color:var(--blue);font-weight:600}

      /* Skills */
      .bp-skills{display:flex;flex-wrap:wrap;gap:.4rem}
      .bp-skill{
        font-family:var(--mono);font-size:.72rem;
        padding:.3rem .7rem;border:1px solid var(--line);color:var(--white);
        transition:all .3s;
      }
      .bp-skill:hover{
        border-color:var(--blue);color:var(--blue);
        box-shadow:0 0 10px var(--blue-glow);
      }

      /* Experience */
      .bp-exp-item{
        padding:1rem 0;
        border-bottom:1px dashed var(--line);
      }
      .bp-exp-item:last-child{border-bottom:none}

      .bp-exp-header{
        display:flex;flex-wrap:wrap;justify-content:space-between;
        align-items:baseline;gap:.5rem;margin-bottom:.3rem;
      }
      .bp-exp-role{font-size:1rem;font-weight:700;color:var(--white)}
      .bp-exp-company{font-weight:400;color:var(--blue)}
      .bp-exp-date{font-family:var(--mono);font-size:.72rem;color:var(--dim)}

      .bp-exp-bullets{list-style:none;padding:0}
      .bp-exp-bullets li{
        font-size:.85rem;padding:.15rem 0 .15rem 1.5rem;position:relative;
      }
      .bp-exp-bullets li::before{
        content:'>';font-family:var(--mono);position:absolute;left:0;color:var(--blue);font-size:.8rem;
      }

      /* Dimension annotation */
      .bp-dimension{
        font-family:var(--mono);font-size:.6rem;color:var(--dim);
        text-align:right;margin-top:.5rem;
      }
      .bp-dimension span{color:var(--blue)}

      /* Projects */
      .bp-proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:1rem}
      .bp-proj{
        border:1px solid var(--line);padding:1.2rem;position:relative;
        transition:all .3s;
      }
      .bp-proj::before{
        content:'';position:absolute;top:-1px;right:-1px;width:12px;height:12px;
        border-top:2px solid var(--blue);border-right:2px solid var(--blue);
      }
      .bp-proj:hover{border-color:var(--line-bright);box-shadow:0 0 20px var(--blue-glow)}

      .bp-proj h3{font-size:.95rem;font-weight:700;color:var(--white)}
      .bp-proj .ptype{font-size:.72rem;color:var(--blue)}
      .bp-proj .plink{font-family:var(--mono);font-size:.68rem;margin:.2rem 0}
      .bp-proj .plink a{color:var(--dim);text-decoration:none}
      .bp-proj .plink a:hover{color:var(--blue)}
      .bp-proj p{font-size:.8rem;color:var(--dim);line-height:1.5;margin-top:.2rem}
      .bp-proj .ptags{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.5rem}
      .bp-proj .ptags span{font-family:var(--mono);font-size:.62rem;padding:.15rem .4rem;border:1px solid var(--line);color:var(--blue)}

      /* Two column */
      .bp-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1rem}

      .bp-info-box{
        border:1px solid var(--line);padding:1.2rem;position:relative;
      }
      .bp-info-box::before{
        content:'';position:absolute;top:-1px;left:-1px;width:10px;height:10px;
        border-top:2px solid var(--blue);border-left:2px solid var(--blue);
      }

      .bp-info-box h3{font-size:.95rem;font-weight:700;color:var(--white);margin-bottom:.2rem}
      .bp-info-box p{font-size:.85rem;color:var(--blue)}

      .bp-lang-list{display:flex;flex-wrap:wrap;gap:.8rem}
      .bp-lang{font-size:.88rem}
      .bp-lang .name{font-weight:600;color:var(--white)}
      .bp-lang .level{font-family:var(--mono);font-size:.72rem;color:var(--dim);margin-left:.2rem}

      /* Footer */
      .bp-footer{
        margin-top:2rem;padding:1.5rem;
        border:1px solid var(--line);position:relative;
        display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem;
      }
      .bp-footer::before,.bp-footer::after{
        content:'';position:absolute;width:15px;height:15px;
        border-color:var(--blue);border-style:solid;
      }
      .bp-footer::before{top:-1px;left:-1px;border-width:2px 0 0 2px}
      .bp-footer::after{bottom:-1px;right:-1px;border-width:0 2px 2px 0}

      .bp-footer p{font-size:.85rem;color:var(--dim)}
      .bp-footer a{color:var(--blue);text-decoration:none;font-weight:600}
      .bp-footer-links{display:flex;gap:1.5rem}
      .bp-footer-links a{font-family:var(--mono);font-size:.72rem;color:var(--dim);text-decoration:none}
      .bp-footer-links a:hover{color:var(--blue)}

      @media(max-width:640px){
        .bp-hero{padding:2rem}
        .bp-section{padding:1.2rem}
        .bp-exp-header{flex-direction:column}
        .bp-proj-grid{grid-template-columns:1fr}
        .bp-two-col{grid-template-columns:1fr}
      }

      @media print{
        body::before{display:none}
        body{background:#fff;color:#1a1a1a}
        .bp-hero,.bp-section,.bp-footer,.bp-proj,.bp-info-box{border-color:#ddd}
        .bp-hero::before,.bp-hero::after,.bp-footer::before,.bp-footer::after,.bp-proj::before,.bp-info-box::before{display:none}
        .back-link{display:none}
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
