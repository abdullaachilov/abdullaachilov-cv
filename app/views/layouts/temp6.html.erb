<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Abdulla Achilov | Editorial</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23111'/><text x='50' y='72' text-anchor='middle' font-size='60' font-family='Georgia,serif' fill='%23fff'>A</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap');

      *{margin:0;padding:0;box-sizing:border-box}

      :root{
        --bg:#fafafa;
        --black:#0f0f0f;
        --text:#2a2a2a;
        --dim:#888;
        --accent:#0f0f0f;
        --line:rgba(0,0,0,0.08);
        --serif:'Playfair Display',Georgia,serif;
        --sans:'Inter',sans-serif;
      }

      body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.6}

      .ed-page{max-width:1000px;margin:0 auto;padding:2rem 2rem 5rem}

      .back-link{display:inline-block;font-size:.75rem;color:var(--dim);text-decoration:none;margin-bottom:2rem;text-transform:uppercase;letter-spacing:.15em;font-weight:500}
      .back-link:hover{color:var(--black)}

      /* Masthead */
      .masthead{
        border-top:4px solid var(--black);border-bottom:1px solid var(--black);
        padding:1rem 0;margin-bottom:3rem;
        display:flex;justify-content:space-between;align-items:center;
      }
      .masthead-left{font-family:var(--serif);font-size:.85rem;letter-spacing:.1em;text-transform:uppercase}
      .masthead-right{font-size:.75rem;color:var(--dim);letter-spacing:.1em;text-transform:uppercase}

      /* Hero spread */
      .ed-hero{
        display:grid;grid-template-columns:1fr 1fr;gap:3rem;
        margin-bottom:4rem;min-height:400px;
      }

      .ed-hero-left{
        display:flex;flex-direction:column;justify-content:center;
      }

      .ed-hero-left h1{
        font-family:var(--serif);font-size:clamp(3rem,7vw,5.5rem);
        font-weight:900;line-height:.95;letter-spacing:-.03em;
        color:var(--black);margin-bottom:1rem;
      }

      .ed-hero-left .title{
        font-family:var(--serif);font-size:1.4rem;font-weight:400;
        font-style:italic;color:var(--dim);margin-bottom:.3rem;
      }

      .ed-hero-left .sub{
        font-size:.8rem;color:var(--dim);letter-spacing:.15em;text-transform:uppercase;
        margin-bottom:.3rem;
      }

      .ed-hero-left .loc{font-size:.85rem;color:var(--dim)}

      .ed-hero-right{
        background:var(--black);color:white;padding:3rem;
        display:flex;flex-direction:column;justify-content:center;
      }

      .ed-hero-right .sum{
        font-family:var(--serif);font-size:1.15rem;font-weight:400;
        line-height:1.8;color:rgba(255,255,255,0.85);
      }

      .ed-hero-right .sum strong{color:#fff;font-weight:600}

      .ed-contacts{
        display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1.5rem;
      }
      .ed-contacts a{
        font-size:.75rem;letter-spacing:.05em;color:rgba(255,255,255,0.5);
        text-decoration:none;padding:.35rem .7rem;border:1px solid rgba(255,255,255,0.15);
        transition:all .2s;
      }
      .ed-contacts a:hover{color:#fff;border-color:rgba(255,255,255,0.5)}

      /* Marquee-style divider */
      .marquee-div{
        overflow:hidden;padding:.8rem 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);
        margin-bottom:3rem;
      }
      .marquee-inner{
        display:flex;gap:3rem;animation:scroll-x 25s linear infinite;white-space:nowrap;
      }
      .marquee-inner span{
        font-family:var(--serif);font-size:.85rem;font-style:italic;color:var(--dim);
      }
      @keyframes scroll-x{from{transform:translateX(0)}to{transform:translateX(-50%)}}

      /* Section */
      .ed-section{margin-bottom:3.5rem}
      .ed-label{
        font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:.3em;
        color:var(--dim);margin-bottom:1.5rem;padding-bottom:.5rem;border-bottom:1px solid var(--line);
      }

      /* Skills as inline */
      .ed-skills{
        font-family:var(--serif);font-size:1.1rem;line-height:2;
        color:var(--text);
      }
      .ed-skills span{
        display:inline-block;margin-right:.3rem;
      }
      .ed-skills .sep{color:var(--dim);margin:0 .2rem}

      /* Experience - editorial columns */
      .ed-exp-grid{
        display:grid;grid-template-columns:180px 1fr;gap:0;
        border-top:1px solid var(--black);
      }

      .ed-exp-item{
        display:contents;
      }

      .ed-exp-date{
        padding:1.2rem 1rem 1.2rem 0;
        font-size:.75rem;color:var(--dim);letter-spacing:.05em;
        border-bottom:1px solid var(--line);
        font-weight:500;
      }

      .ed-exp-content{
        padding:1.2rem 0 1.2rem 1.5rem;
        border-bottom:1px solid var(--line);
        border-left:1px solid var(--line);
      }

      .ed-exp-content .role{font-size:1.05rem;font-weight:700;color:var(--black)}
      .ed-exp-content .company{font-family:var(--serif);font-style:italic;color:var(--dim);font-size:.95rem}

      .ed-exp-content ul{list-style:none;padding:0;margin-top:.4rem}
      .ed-exp-content ul li{font-size:.85rem;padding:.15rem 0 .15rem 1rem;position:relative;color:var(--text)}
      .ed-exp-content ul li::before{
        content:'\2014';position:absolute;left:0;color:var(--dim);
      }

      /* Projects - magazine cards */
      .ed-proj-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border:1px solid var(--black)}

      .ed-proj{
        padding:1.8rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);
        transition:background .3s;
      }
      .ed-proj:hover{background:var(--black);color:#fff}
      .ed-proj:hover h3{color:#fff}
      .ed-proj:hover .ptype{color:rgba(255,255,255,0.6)}
      .ed-proj:hover .plink a{color:rgba(255,255,255,0.5)}
      .ed-proj:hover p{color:rgba(255,255,255,0.7)}
      .ed-proj:hover .ptags span{color:rgba(255,255,255,0.5)}

      .ed-proj h3{font-family:var(--serif);font-size:1.2rem;font-weight:700;color:var(--black);transition:color .3s}
      .ed-proj .ptype{font-size:.75rem;color:var(--dim);font-style:italic;transition:color .3s}
      .ed-proj .plink{font-size:.7rem;margin:.2rem 0}
      .ed-proj .plink a{color:var(--dim);text-decoration:none;transition:color .3s}
      .ed-proj p{font-size:.8rem;color:var(--dim);margin-top:.3rem;line-height:1.5;transition:color .3s}
      .ed-proj .ptags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.5rem}
      .ed-proj .ptags span{font-size:.7rem;color:var(--dim);letter-spacing:.05em;transition:color .3s}
      .ed-proj .ptags span::before{content:'#'}

      /* Two-column info */
      .ed-two-col{display:grid;grid-template-columns:1fr 1fr;gap:3rem}

      .ed-edu h3{font-family:var(--serif);font-size:1.3rem;font-weight:700;color:var(--black)}
      .ed-edu p{font-family:var(--serif);font-style:italic;color:var(--dim);font-size:.95rem}

      .ed-langs{display:flex;flex-wrap:wrap;gap:1.5rem}
      .ed-lang .name{font-weight:600;color:var(--black);font-size:.95rem}
      .ed-lang .level{font-size:.8rem;color:var(--dim);margin-left:.2rem;font-style:italic}

      /* Footer */
      .ed-footer{
        margin-top:3rem;padding:2rem 0;
        border-top:4px solid var(--black);
        display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem;
      }
      .ed-footer p{font-size:.85rem;color:var(--dim)}
      .ed-footer a{color:var(--black);text-decoration:none;font-weight:600}
      .ed-footer-links{display:flex;gap:1.5rem}
      .ed-footer-links a{font-size:.8rem;color:var(--dim);text-decoration:none;font-weight:400;text-transform:uppercase;letter-spacing:.1em}
      .ed-footer-links a:hover{color:var(--black)}

      @media(max-width:768px){
        .ed-hero{grid-template-columns:1fr;gap:0}
        .ed-hero-right{padding:2rem}
        .ed-exp-grid{grid-template-columns:1fr}
        .ed-exp-date{border-bottom:none;padding-bottom:0}
        .ed-exp-content{border-left:none;padding-left:0}
        .ed-proj-grid{grid-template-columns:1fr}
        .ed-two-col{grid-template-columns:1fr;gap:2rem}
        .masthead{flex-direction:column;gap:.5rem;text-align:center}
      }

      @media print{
        .back-link,.marquee-div{display:none}
        .ed-hero-right{background:#333;-webkit-print-color-adjust:exact;print-color-adjust:exact}
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
